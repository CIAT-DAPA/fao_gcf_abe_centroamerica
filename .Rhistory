stk_crop <- crop(stk, mask)
stk_mask <- mask(stk_crop, mask)
# if (var == "tmax" || var == "tmin"){
#   if (gcm == "cnrm_cm6_1_hr" || gcm == "ec_earth3_veg_lr" || gcm == "giss_e2_1_g" || gcm == "giss_e2_1_h" || gcm == "mpi_esm1_2_hr" || gcm == "mpi_esm1_2_lr"){
