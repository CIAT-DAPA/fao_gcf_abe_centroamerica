for (var in var_list){
rs_flname <- paste0(gcm, "_", str_replace(scn, "_", ""), "_", per, "_", var, "_", str_replace(res, "in", ""), "_no_tile_tif.tif")
if (!file.exists(paste0(ot_dir_gcm, "/", var, "_12.tif"))) {
