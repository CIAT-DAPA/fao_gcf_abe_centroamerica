msk <- "E:/fao_gcf_abe/00_admin_data/dom_msk_2_5m.tif"
res <- "2_5min"
reg <- "dom"
ot_dir <- "E:/fao_gcf_abe/02_climate_change"
seasons <- list("djf"=c(12,1,2), "mam"=3:5, "jja"=6:8, "son"=9:11, "ann"=1:12)
