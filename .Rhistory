# }
##Write outputfile
for (i in 1:nlayers(stk_mask)){
if (!file.exists(paste0(ot_dir_gcm, "/", var, "_", i, ".tif"))) {
cat(paste0(scn, " ", gcm, " ",  per, " ", var, " ", i, " done!","\n"))
writeRaster(stk_mask[[i]], paste0(ot_dir_gcm, "/", var, "_", i, ".tif"), overwrite=TRUE, format="GTiff")
}
}
}
}
}
}
}
