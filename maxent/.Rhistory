outFolder <- paste(inputDir, "/mxe_outputs", sep="")
mask_adm1 <- as(vect("Y:/1.Data/RAW/Admin/COL1_HUI.shp"), "Spatial")
mask_adm2 <- as(vect("Y:/1.Data/RAW/Admin/COL2_HUI.shp"), "Spatial")
projectionList <- c("ssp126/2030s","ssp245/2030s","ssp585/2030s",
"ssp126/2050s","ssp245/2050s","ssp585/2050s")
id <- c("2030s SSP1-2.6", "2030s SSP2-4.5", "2030s SSP5-8.5",
"2050s SSP1-2.6", "2050s SSP2-4.5", "2030s SSP5-8.5"
)
sspLsMod <- c("SSP1-2.6", "SSP2-4.5", "SSP5-8.5")
yearLs <- c("2030s", "2050s")
projectionList <- gsub("/", "_", projectionList)
oDir <- paste0(outFolder, "/_plots")
if (!file.exists(oDir)) {dir.create(oDir)}
for(spID in speciesList){
outName <- paste0(outFolder, "/sp-", spID)
suitH <- raster(paste(outName, "/crossval/", paste0(toupper(substr(spID, 1, 1)), substr(spID, 2, nchar(spID))), "_average_avg.asc", sep="")) *100
suitH_crop <- mask(crop(suitH, extent(mask_adm1)), mask_adm1)
id_mod <-c("CUR")
plot <- setZ(suitH_crop, id_mod)
names(plot) <- toupper(id_mod)
