outName <- paste0(outFolder, "/sp-", spID)
suitH <- raster(paste(outName, "/crossval/", paste0(toupper(substr(spID, 1, 1)), substr(spID, 2, nchar(spID))), "_", suffix , "_avg.asc", sep="")) *100
